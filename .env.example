# ─── Next.js ───────────────────────────────────────────
# Node environment
NODE_ENV=development

# Application port (default: 3000)
PORT=3000

# Hostname to bind to (default: 0.0.0.0)
HOSTNAME=0.0.0.0

# Disable Next.js telemetry (1 to disable)
NEXT_TELEMETRY_DISABLED=1

# Node.js runtime options (e.g., memory limit)
# NODE_OPTIONS=--max-old-space-size=6144

# ─── GitHub API ───────────────────────────────────────
# Generate one at: https://github.com/settings/tokens
GITHUB_TOKEN=

# ─── Vercel (optional, for preview deployments) ──────
# VERCEL_ORG_ID=
# VERCEL_PROJECT_ID=
# VERCEL_TOKEN=

# ─── Umami Analytics ─────────────────────────────────
# Self-hosted privacy-focused analytics. Set these to enable tracking.
# NEXT_PUBLIC_UMAMI_SRC=https://stats.hoa.moe/script.js
# NEXT_PUBLIC_UMAMI_WEBSITE_ID=300d85bd-f997-42d4-9bcf-b26666daa293
